<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <!-- ========== CONFIGURATION À MODIFIER PAR TP ========== -->
    <groupId>fr.univ_amu.iut</groupId>
    <artifactId>tp5</artifactId>
    <name>TP5</name>
    <!-- ====================================================== -->

    <packaging>jar</packaging>
    <version>1.0-SNAPSHOT</version>
    <url>https://github.com/IUTInfoAix-R202</url>

    <properties>
        <!-- Encoding -->
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>

        <!-- Java & JavaFX versions -->
        <maven.compiler.release>25</maven.compiler.release>
        <javafx.version>26</javafx.version>
        <javafx.mainClass>tp5.javafx/fr.univ_amu.iut.App</javafx.mainClass>

        <!-- Plugin versions -->
        <javafx.maven.plugin.version>0.0.8</javafx.maven.plugin.version>
        <maven.compiler.plugin.version>3.15.0</maven.compiler.plugin.version>
        <maven.surefire.plugin.version>3.5.6</maven.surefire.plugin.version>
        <maven.shade.plugin.version>3.6.2</maven.shade.plugin.version>
        <spotless.maven.plugin.version>3.4.0</spotless.maven.plugin.version>
        <google.java.format.version>1.35.0</google.java.format.version>
        <git.build.hook.plugin.version>3.6.0</git.build.hook.plugin.version>

        <!-- Persistance et injection de dependances -->
        <sqlite.jdbc.version>3.53.1.0</sqlite.jdbc.version>
        <guice.version>7.0.0</guice.version>
        <hikaricp.version>6.3.0</hikaricp.version>
        <!-- SLF4J : doit rester aligne sur le slf4j-api tire transitivement par
             HikariCP (1.7.36). Le binding NOP supprime le message d'init SLF4J. -->
        <slf4j.version>2.0.18</slf4j.version>

        <!-- Test dependencies versions -->
        <junit.jupiter.version>6.1.0</junit.jupiter.version>
        <assertj.version>3.27.7</assertj.version>
        <testfx.version>4.0.18</testfx.version>
        <mockito.version>5.23.0</mockito.version>
        <approvaltests.version>30.1.1</approvaltests.version>
    </properties>

    <dependencies>
        <!-- JavaFX -->
        <dependency>
            <groupId>org.openjfx</groupId>
            <artifactId>javafx-controls</artifactId>
            <version>${javafx.version}</version>
        </dependency>
        <dependency>
            <groupId>org.openjfx</groupId>
            <artifactId>javafx-fxml</artifactId>
            <version>${javafx.version}</version>
        </dependency>
        <dependency>
            <groupId>org.openjfx</groupId>
            <artifactId>javafx-graphics</artifactId>
            <version>${javafx.version}</version>
        </dependency>
        <dependency>
            <groupId>org.openjfx</groupId>
            <artifactId>javafx-media</artifactId>
            <version>${javafx.version}</version>
        </dependency>

        <!-- SQLite : driver JDBC + DataSource (coeur du TP5) -->
        <dependency>
            <groupId>org.xerial</groupId>
            <artifactId>sqlite-jdbc</artifactId>
            <version>${sqlite.jdbc.version}</version>
        </dependency>

        <!-- Guice 7 : injection de dependances (DataSource et DAO injectes) -->
        <dependency>
            <groupId>com.google.inject</groupId>
            <artifactId>guice</artifactId>
            <version>${guice.version}</version>
        </dependency>

        <!-- HikariCP : pool de connexions (bonus 9) -->
        <dependency>
            <groupId>com.zaxxer</groupId>
            <artifactId>HikariCP</artifactId>
            <version>${hikaricp.version}</version>
        </dependency>

        <!-- SLF4J NOP : binding "silencieux". HikariCP utilise SLF4J ; sans binding,
             SLF4J affiche au demarrage "Failed to load StaticLoggerBinder / NOP logger".
             Le binding NOP fournit org.slf4j.impl.StaticLoggerBinder et neutralise tous
             les logs. Module JPMS stable org.slf4j.nop, declare dans module-info.java. -->
        <dependency>
            <groupId>org.slf4j</groupId>
            <artifactId>slf4j-nop</artifactId>
            <version>${slf4j.version}</version>
        </dependency>

        <!-- JUnit 5 -->
        <dependency>
            <groupId>org.junit</groupId>
            <artifactId>junit-bom</artifactId>
            <version>${junit.jupiter.version}</version>
            <type>pom</type>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter</artifactId>
            <version>${junit.jupiter.version}</version>
            <scope>test</scope>
        </dependency>

        <!-- AssertJ -->
        <dependency>
            <groupId>org.assertj</groupId>
            <artifactId>assertj-core</artifactId>
            <version>${assertj.version}</version>
            <scope>test</scope>
        </dependency>

        <!-- ApprovalTests -->
        <dependency>
            <groupId>com.approvaltests</groupId>
            <artifactId>approvaltests</artifactId>
            <version>${approvaltests.version}</version>
            <scope>test</scope>
        </dependency>

        <!-- TestFX -->
        <dependency>
            <groupId>org.testfx</groupId>
            <artifactId>testfx-core</artifactId>
            <version>${testfx.version}</version>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.testfx</groupId>
            <artifactId>testfx-junit5</artifactId>
            <version>${testfx.version}</version>
            <scope>test</scope>
        </dependency>

        <!-- Mockito -->
        <dependency>
            <groupId>org.mockito</groupId>
            <artifactId>mockito-junit-jupiter</artifactId>
            <version>${mockito.version}</version>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <resources>
            <resource>
                <directory>src/main/resources</directory>
                <includes>
                    <include>**/*</include>
                </includes>
            </resource>
            <!--
              Permet de placer les ressources (.sql, .fxml, .css, ...) directement
              a cote de la classe Java. Tous les fichiers non-Java de src/main/java
              sont copies dans target/classes au meme chemin de paquetage.
            -->
            <resource>
                <directory>src/main/java</directory>
                <excludes>
                    <exclude>**/*.java</exclude>
                </excludes>
            </resource>
        </resources>

        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>${maven.compiler.plugin.version}</version>
                <configuration>
                    <release>${maven.compiler.release}</release>
                </configuration>
            </plugin>

            <plugin>
                <groupId>org.openjfx</groupId>
                <artifactId>javafx-maven-plugin</artifactId>
                <version>${javafx.maven.plugin.version}</version>
                <configuration>
                    <jlinkImageName>app</jlinkImageName>
                    <launcher>launcher</launcher>
                    <mainClass>${javafx.mainClass}</mainClass>
                    <options>
                        <option>--enable-native-access=javafx.graphics</option>
                        <option>--enable-native-access=org.xerial.sqlitejdbc</option>
                        <!-- Neutralise le WARNING sun.misc.Unsafe de Guice/Guava (JEP 498). -->
                        <option>--sun-misc-unsafe-memory-access=allow</option>
                    </options>
                </configuration>
            </plugin>

            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-shade-plugin</artifactId>
                <version>${maven.shade.plugin.version}</version>
                <executions>
                    <execution>
                        <phase>package</phase>
                        <goals>
                            <goal>shade</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>

            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <version>${maven.surefire.plugin.version}</version>
                <configuration>
                    <!-- TestFX requires classpath mode (not module path) -->
                    <useModulePath>false</useModulePath>
                    <!-- Headless Platform JavaFX 26 (Gluon) : plateforme Glass logicielle, sans
                         natif ni serveur d'affichage. Aucune fenêtre TestFX/JavaFX n'apparaît à
                         l'écran, localement comme en CI, et plus besoin de xvfb. Le robot Glass
                         pilote la plateforme Headless, le pipeline de rendu logiciel (sw)
                         remplace le GPU. Remplace l'ancien bricolage Monocle.
                         NB : on NE met PAS testfx.headless=true : ce flag déclencherait le vieux
                         bootstrap Monocle de TestFX (recherche de MonoclePlatformFactory, classe
                         absente sans la dépendance monocle). Le headless vient ici de
                         glass.platform=Headless, pas de TestFX. -->
                    <systemPropertyVariables>
                        <glass.platform>Headless</glass.platform>
                        <prism.order>sw</prism.order>
                        <java.awt.headless>true</java.awt.headless>
                        <testfx.robot>glass</testfx.robot>
                    </systemPropertyVariables>
                    <!-- En mode classpath (useModulePath=false ci-dessus), JavaFX et SQLite
                         sont charges dans le module *unnamed* : les modules nommes javafx.graphics,
                         javafx.base et org.xerial.sqlitejdbc n'existent pas dans le graphe. Tout
                         flag add-reads / add-exports / add-opens ou enable-native-access qui les
                         cible declenche "WARNING: Unknown module ..." et reste sans effet (les
                         classes com.sun.javafx.* de l'unnamed sont deja ouvertes/accessibles). On
                         ne garde donc que ALL-UNNAMED, seule cible active, qui couvre l'acces natif
                         du JavaFX headless et du driver JNI SQLite.
                         On ajoute sun-misc-unsafe-memory-access=allow (JEP 498, Java 24+) pour
                         neutraliser les "WARNING: sun.misc.Unsafe" emis par Guice (HiddenClassDefiner,
                         staticFieldBase) et Guava (AbstractFuture, objectFieldOffset), deux
                         dependances transitives non maitrisees et deja en derniere version. -->
                    <argLine>--enable-native-access=ALL-UNNAMED --sun-misc-unsafe-memory-access=allow</argLine>
                </configuration>
            </plugin>

            <!-- Spotless : formatage Google Java Format. Disponible en
                 opt-in via ./mvnw spotless:apply et automatiquement
                 appelé par le pre-commit hook .githooks/pre-commit.
                 Non lié à verify : pas d'enforcement CI. -->
            <plugin>
                <groupId>com.diffplug.spotless</groupId>
                <artifactId>spotless-maven-plugin</artifactId>
                <version>${spotless.maven.plugin.version}</version>
                <configuration>
                    <java>
                        <googleJavaFormat>
                            <version>${google.java.format.version}</version>
                        </googleJavaFormat>
                        <removeUnusedImports />
                        <trimTrailingWhitespace />
                        <endWithNewline />
                    </java>
                </configuration>
            </plugin>

            <!-- git-build-hook : configure silencieusement
                 core.hooksPath=.githooks au premier ./mvnw, pour que
                 le pre-commit Spotless s'active automatiquement dans
                 chaque clone du TP sans action de l'étudiant. -->
            <plugin>
                <groupId>com.rudikershaw.gitbuildhook</groupId>
                <artifactId>git-build-hook-maven-plugin</artifactId>
                <version>${git.build.hook.plugin.version}</version>
                <configuration>
                    <gitConfig>
                        <core.hooksPath>.githooks</core.hooksPath>
                    </gitConfig>
                </configuration>
                <executions>
                    <execution>
                        <goals>
                            <goal>configure</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>
</project>